#!/usr/bin/env bash
#
# keyhint-2 — show i3 keybindings via rofi
#
# Parses ~/.config/i3/config and renders a searchable list of bindings
# with section headers and human-readable descriptions taken from comments.
#
# Conventions inside the i3 config:
#   # === Section Name ===          → section header, rendered as ── Section Name ──
#   # Description text              → description for the *next* `bindsym` line
#   bindsym KEY ...                 → the binding itself
#   #bindsym ...                    → ignored (commented-out binding)
#
# If a `bindsym` has no description comment above it, the script falls back to
# showing the cleaned-up command (same behaviour as the original keyhint-2).
#
# Key normalization for display:
#   $mod / Mod4 → Super       Mod1 → Alt
#   bracketright → ]          bracketleft → [
#   backslash → \             Return → Enter        space → Space

set -eu

I3_CONFIG="${HOME}/.config/i3/config"
ROFI_THEME="${HOME}/.config/rofi/rofikeyhint.rasi"

awk '
    function clean_keys(s,    name) {
        # Expand any $var references using values collected from `set $var value`
        for (name in vars) gsub("\\$" name, vars[name], s)
        gsub(/Mod4/,         "Super", s)
        gsub(/Mod1/,         "Alt",   s)
        gsub(/bracketright/, "]",     s)
        gsub(/bracketleft/,  "[",     s)
        gsub(/backslash/,    "\\",    s)
        gsub(/Return/,       "Enter", s)
        gsub(/space/,        "Space", s)
        # Multimedia keys → human-readable labels
        gsub(/XF86AudioRaiseVolume/,  "Vol+",    s)
        gsub(/XF86AudioLowerVolume/,  "Vol−",    s)
        gsub(/XF86AudioMute/,         "Mute",    s)
        gsub(/XF86AudioMicMute/,      "MicMute", s)
        gsub(/XF86AudioPlay/,         "Play",    s)
        gsub(/XF86AudioPause/,        "Pause",   s)
        gsub(/XF86AudioNext/,         "Next",    s)
        gsub(/XF86AudioPrev/,         "Prev",    s)
        gsub(/XF86MonBrightnessUp/,   "Bri+",    s)
        gsub(/XF86MonBrightnessDown/, "Bri−",    s)
        return s
    }
    function clean_cmd(s) {
        sub(/^bindsym +/, "", s)
        # drop flag tokens (--release etc.) and the key, until the command starts
        while (s ~ /^--[^ ]+ /) sub(/^--[^ ]+ +/, "", s)
        sub(/^[^ ]+ +/, "", s)
        sub(/^exec +--no-startup-id +/, "", s)
        sub(/^exec +/, "", s)
        return s
    }
    function extract_key(line,    n, parts, i) {
        n = split(line, parts, " ")
        for (i = 2; i <= n; i++) {
            if (parts[i] !~ /^--/) return parts[i]
        }
        return ""
    }

    /^set +\$[A-Za-z_][A-Za-z0-9_]* +/ {
        name = $2
        sub(/^\$/, "", name)
        value = $0
        sub(/^set +\$[A-Za-z_][A-Za-z0-9_]* +/, "", value)
        gsub(/^"|"$/, "", value)
        vars[name] = value
        next
    }

    /^# === .* ===[[:space:]]*$/ {
        title = $0
        sub(/^# === /, "", title)
        sub(/ ===[[:space:]]*$/, "", title)
        printf "── %s ──\n", toupper(title)
        desc = ""
        next
    }

    # Synthetic entry: `# @hint: Description | Keys` renders one row
    # without needing a real bindsym (used for bindcode groups, etc.).
    /^#[[:space:]]*@hint:/ {
        line = $0
        sub(/^#[[:space:]]*@hint:[[:space:]]*/, "", line)
        n = split(line, parts, /[[:space:]]*\|[[:space:]]*/)
        if (n >= 2) {
            printf "%-22s  %s\n", clean_keys(parts[2]), parts[1]
        }
        desc = ""
        next
    }

    /^#[[:space:]]*bindsym/ {
        desc = ""
        next
    }

    /^#/ {
        line = $0
        sub(/^#[[:space:]]*/, "", line)
        desc = line
        next
    }

    /^[[:space:]]*$/ {
        desc = ""
        next
    }

    /^bindsym / {
        keys = extract_key($0)
        text = (desc != "") ? desc : clean_cmd($0)
        printf "%-22s  %s\n", clean_keys(keys), text
        desc = ""
        next
    }

    {
        desc = ""
    }
' "$I3_CONFIG" | rofi -dmenu -i -theme "$ROFI_THEME" -p "Keybindings"
