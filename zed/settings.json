{
  // ==========================================
  // COMMON MODES
  // ==========================================
  "session": {
    "trust_all_worktrees": true,
  },
  "auto_install_extensions": {
    "material-icon-theme": true,
    "gruvbox": true,
    "lua": true,
    "dockerfile": true,
    "sql": true,
    "bash": true,
    "toml": true,
    "make": true,
    "html": true,
    "xml": true,
    "swift": true,
    "ini": true,
    "solidity": true,
    "json5": true,
    "github-theme": true,
    "csv": true,
    "docker-compose": true,
    "pylsp": true,
    "env": true,
    "javascript-snippets": true,
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "play_sound_when_agent_done": "always",
    "default_profile": "ask",
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always", // y / p go to + register by default
    "use_smartcase_find": true, // f / t case-insensitive when pattern is lowercase
    "toggle_relative_line_numbers": true, // relative in normal, absolute in insert
  },
  "restore_on_startup": "last_session",
  "confirm_quit": true,
  "buffer_line_height": "comfortable",
  "project_panel": {
    "dock": "left",
    "file_scan_exclusions": [
      "**/.git",
      "**/target",
      "**/node_modules",
      "**/__pycache__",
      "**/.venv",
      "**/*.lock",
    ],
  },
  // ==========================================
  // PRIVACY SETTINGS
  // ==========================================
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "private_files": [
    "**/.env*",
    "**/*.pem",
    "**/*.key",
    "**/*.cert",
    "**/*.crt",
    "**/secrets.yml",
  ],
  // ==========================================
  // ON SAVE ACTIONS
  // ==========================================
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,

  // ==========================================
  // EDITOR EXPERIENCE
  // ==========================================
  "current_line_highlight": "all",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "show_edit_predictions": true,
  "edit_predictions": {
    "mode": "subtle",
    "disabled_globs": ["**/.env*", "**/*.pem", "**/*.key", "**/secrets*"],
  },
  "scrollbar": {
    "show": "always",
    "diagnostics": "all",
    "git_diff": true,
  },

  // ==========================================
  // THEMES
  // ==========================================
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light",
    "dark": "One Dark",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme",
  },

  // ==========================================
  //  FONTS
  // ==========================================
  // "ui_font_family": "JetBrains Mono",
  "ui_font_size": 14,
  // Editor
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 13,
  "buffer_font_weight": 200,
  "buffer_font_fallbacks": ["Noto Color Emoji"],
  "cursor_blink": true,
  // "color": "red",
  "experimental.theme_overrides": {
    //font colors
    "syntax": {
      "keyword": {
        "color": "#884ea0",
        "font_weight": 400,
        "font_style": "italic",
      },
      "variable": {
        "color": "#FF99CC ",
        "font_weight": 100,
      },
      "string": {
        "color": "#8FAA91",
        "font_weight": 100,
        "font_style": "italic",
      },
      "comment": {
        "color": "#5C6370",
        "font_weight": 100,
        "font_style": "italic",
        // "font-size": "8px"
      },
      "number": {
        "color": "#7dcea0",
        "font_weight": 100,
      },
      "operator": {
        "color": "#c39bd3",
        "font_weight": 100,
      },
      "punctuation": {
        "color": "#c39bd3",
        "font_weight": 100,
      },
      "boolean": {
        "color": "#ca6f1e",
        "font_weight": 100,
      },
      "null": {
        "color": "#8FAA91",
        "font_weight": 100,
      },
      "undefined": {
        "color": "#8FAA91",
        "font_weight": 100,
      },
      "key": {
        "color": "#a9cce3",
        "font_weight": 100,
      },
      "value": {
        "color": "#8FAA91",
        "font_weight": 100,
      },
      "property": {
        "color": "#ffebee",
        "font_weight": 100,
      },
      "attribute": {
        "color": "#E5C07B",
        "font_weight": 100,
      },
      "namespaces": {
        "color": "#56B6C2",
        "font_weight": 200,
      },
      "names": {
        "color": "#D19A66",
        "font_weight": 200,
      },
      "constant": {
        "color": "#e57373",
        "font_weight": 200,
      },
      "functions": {
        "color": "#61AFEF",
        "font_weight": 200,
      },
      "brackets": {
        "color": "#FF0000",
        "font_weight": 100,
      },
      "cursor": {
        "color": "#85c1e9",
        "font_weight": 400,
      },
      "module": {
        "color": "#FF0000",
        "font_weight": 200,
      },
      "type": {
        "color": "#00796b",
        "font_weight": 100,
        "font_style": "italic",
      },
      "method": {
        "color": "#0288d1",
        "font_weight": 100,
      },
      "import": {
        "color": "#FF0000",
        "font_weight": 100,
      },
      "export": {
        "color": "#FF0000",
        "font_weight": 100,
      },

      // "inlayhints": {
      //   "color": "#FF5555",
      //   "font_weight": 100
      // }
    },
  },
  // ==========================================
  // TERMINAL
  // ==========================================
  "terminal": {
    "font_family": "JetBrains Mono",
    "font_size": 12,
    "font_weight": 200,
    "blinking": "on",
    "cursor_shape": "bar",
    "max_scroll_history_lines": 100000,
  },
  // ==========================================
  //  OUTLINE PANEL
  //==========================================
  "outline_panel": {
    "indent_size": 1,
  },

  //==========================================
  // GIT
  // ==========================================
  "git": {
    "git_gutter": "tracked_files",
    "gutter_debounce": 3000,
  },

  "tabs": {
    "git_status": true,
    "show_diagnostics": "all",
  },

  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "toggle_on_modifier_press": "alt",
  },
  "spell_check": true,
  "spell_check_languages": ["en_US", "ru_RU"],
  "file_types": {
    // "C++": ["mq4", "mq5", "mqh", "c"], // .c is plain C, not C++
    "C++": ["mq4", "mq5", "mqh"],
  },
  "languages": {
    "Rust": {
      "tab_size": 4,
      "hard_tabs": false,
      // "formatter": ["rustfmt"],
      "format_on_save": "on",
      "language_servers": ["rust-analyzer"],
    },
    "Python": {
      "tab_size": 4,
      "hard_tabs": false,
      "formatter": "auto",
      "format_on_save": "on",
      "language_servers": ["pyright"],
    },
    "JavaScript": {
      "tab_size": 2,
      "hard_tabs": false,
      "formatter": "prettier",
      "format_on_save": "on",
      // "language_servers": ["typescript"], // wrong id; real LSP is typescript-language-server
      "language_servers": ["typescript-language-server"],
    },
    "Markdown": {
      "soft_wrap": "editor_width",
      "format_on_save": "off",
      "remove_trailing_whitespace_on_save": false,
    },
    "C++": {
      "format_on_save": "on",
      "tab_size": 3,
    },
    "Make": {
      "tab_size": 4,
      "hard_tabs": true,
      "format_on_save": "off",
      "formatter": null,
    },
    // "ini": { ... }, // wrong case — Zed registers the language as "INI"
    "INI": {
      "tab_size": 4,
      "hard_tabs": false,
      "formatter": "language_server",
      "format_on_save": "on",
      "show_edit_predictions": false,
    },
  },

  // ==========================================
  // LSP
  // ==========================================
  "lsp": {
    "rust-analyzer": {
      "binary": {
        "path": "/usr/lib/rustup/bin/rust-analyzer",
        // "arguments": [], // empty array duplicates default; safe to drop
      },
      "initialization_options": {
        "cargo": {
          "allFeatures": true,
          // "loadOutDirsFromCheck": true, // deprecated in ra >=2024; replaced by buildScripts.enable
          "buildScripts": { "enable": true },
        },
        "procMacro": { "enable": true },
        // "checkOnSave": { "command": "clippy" }, // ra now expects boolean; command moved to "check"
        "checkOnSave": true,
        "check": { "command": "clippy" },
      },
    },
  },
}
