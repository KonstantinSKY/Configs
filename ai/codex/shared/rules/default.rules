prefix_rule(pattern=["dunstctl", "reload"], decision="allow")
prefix_rule(pattern=["git", "add", "flatpak/Makefile"], decision="allow")
prefix_rule(pattern=["docker", "ps"], decision="allow")
prefix_rule(pattern=["id", "-nG"], decision="allow")
prefix_rule(pattern=["make", "-f", "bluetooth/Makefile", "status"], decision="allow")
prefix_rule(pattern=["systemctl", "is-active"], decision="allow")
prefix_rule(pattern=["systemctl", "is-enabled"], decision="allow")
prefix_rule(pattern=["systemctl", "status", "docker.socket"], decision="allow")
prefix_rule(pattern=["systemctl", "cat", "docker.service", "docker.socket"], decision="allow")
prefix_rule(pattern=["ls", "-ln", "/run/docker.sock", "/var/run/docker.sock"], decision="allow")
prefix_rule(pattern=["getent", "group", "docker"], decision="allow")
prefix_rule(pattern=["ls", "-l", "/run/docker.sock", "/var/run/docker.sock"], decision="allow")
