# tmux session aliases: t1/t2/t3 attach to (or create) host-scoped sessions
# tl lists all sessions
_tmux_slot() {
    local slot="$1"
    local host="${HOST%%.*}"
    local session="${host}:${slot}"

    tmux attach-session -t "$session" 2>/dev/null && return

    if tmux has-session -t "$slot" 2>/dev/null; then
        tmux rename-session -t "$slot" "$session"
        tmux attach-session -t "$session"
        return
    fi

    tmux new-session -s "$session"
}

for _t in 1 2 3 4 5; do
    alias "t$_t"="_tmux_slot $_t"
done
unset _t
alias tl="tmux list-sessions"
