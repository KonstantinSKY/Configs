# Skip if not interactive
case $- in
  *i*) ;;
  *) return ;;
esac

[[ -d "$HOME/Work" ]] && WORK="$HOME/Work" || WORK="$HOME"

export CONFIGS_PATH="$WORK/Configs"
export PROJECTS_PATH="$WORK/Projects"
export BACKUPS_PATH="$WORK/BackUps"
export PATH="$HOME/.cargo/bin:$PATH"

alias Configs='cd $CONFIGS_PATH; ls -ls'
alias Projects='cd $PROJECTS_PATH; ls -ls'

ai() {
  command make -s -C "$CONFIGS_PATH/ai" "$@"
}

# fnm
FNM_PATH="$HOME/.local/share/fnm"
if [ -d "$FNM_PATH" ]; then
  export PATH="$FNM_PATH:$PATH"
fi
if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env --use-on-cd --shell zsh)"
fi

if command -v bat > /dev/null 2>&1; then
    alias cat='bat --paging=never'
    alias lcat='/usr/bin/cat'
fi

la() { command ls "$@" -la --color=auto; }
chx() { command chmod u+x "$@"; }

cdl() {
  cd "$@" && ls -la --color=auto
}

z() {
  if [ -n "$1" ]; then
    zeditor "$1"
  else
    zeditor .
  fi
}

# Send deletes to trash when the helper is available.
if command -v trash >/dev/null 2>&1; then
  alias rm='trash'
  alias trashbox='trash --help'
fi

alias rsss="remote_start_sudo_script.sh"
alias server="ssh server"

_pw_pull() {
  command pass git pull --rebase --autostash
}

_pw_push() {
  command pass git push || {
    echo "pass push failed; local commit is kept"
    return 1
  }
}

pw() {
  _pw_pull || return
  command pass "$@"
}

pws() {
  command pass git status --short --branch
}

pwsync() {
  _pw_pull || return
  _pw_push
}

pwedit() {
  _pw_pull || return
  command pass edit "$@" || return
  _pw_push
}

pwadd() {
  _pw_pull || return
  command pass insert "$@" || return
  _pw_push
}

pwgen() {
  _pw_pull || return
  command pass generate "$@" || return
  _pw_push
}

choose_editor() {
  if command -v nvim >/dev/null 2>&1; then
    command nvim "$@"
  elif command -v vim >/dev/null 2>&1; then
    command vim "$@"
  else
    command vi "$@"
  fi
}
alias v=choose_editor
alias vi=choose_editor

